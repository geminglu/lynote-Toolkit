{
  "name": "lynote-Toolkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "preview": "pnpm build && pnpm dlx serve out",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "check": "pnpm lint && pnpm type-check && pnpm format:check",
    "lint-staged": "lint-staged",
    "prepare": "husky install"
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "culori": "^4.0.2",
    "dexie": "^4.3.0",
    "fast-xml-parser": "^5.5.9",
    "hash-wasm": "^4.12.0",
    "jsqr": "^1.4.0",
    "lucide": "^1.0.1",
    "lucide-react": "^1.0.1",
    "lynote-ui": "^0.0.7",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "pnpm": {
    "overrides": {
      "slate": "0.118.1",
      "slate-dom": "0.118.1",
      "slate-react": "0.117.4"
    }
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "lint-staged": {
    "**/*.{json,css,md,mdx}": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
